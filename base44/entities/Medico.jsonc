{
  "name": "Medico",
  "type": "object",
  "title": "M\u00e9dico",
  "description": "Cadastro estruturado de m\u00e9dicos utilizados em atestados m\u00e9dicos.",
  "properties": {
    "nome": {
      "type": "string",
      "default": ""
    },
    "crm": {
      "type": "string",
      "default": ""
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "observacoes": {
      "type": "string",
      "default": ""
    }
  },
  "required": [
    "nome",
    "crm"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {}
      ]
    },
    "write": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}