{
  "name": "ProcedimentoProcesso",
  "type": "object",
  "title": "Procedimento e Processo",
  "properties": {
    "tipo_procedimento": {
      "type": "string",
      "default": ""
    },
    "numero_procedimento": {
      "type": "string",
      "default": ""
    },
    "numero_portaria": {
      "type": "string",
      "default": ""
    },
    "data_portaria": {
      "type": "string",
      "format": "date",
      "default": ""
    },
    "data_instauracao": {
      "type": "string",
      "format": "date",
      "default": ""
    },
    "prazo_final": {
      "type": "string",
      "format": "date",
      "default": ""
    },
    "autoridade_instauradora": {
      "type": "string",
      "default": ""
    },
    "responsavel_id": {
      "type": "string",
      "default": ""
    },
    "responsavel_nome": {
      "type": "string",
      "default": ""
    },
    "unidade": {
      "type": "string",
      "default": ""
    },
    "objeto": {
      "type": "string",
      "default": ""
    },
    "sigiloso": {
      "type": "boolean",
      "default": false
    },
    "observacoes": {
      "type": "string",
      "default": ""
    },
    "status": {
      "type": "string",
      "enum": ["Em andamento", "Concluído", "Encerrado", "Suspenso", "Arquivado"],
      "default": "Em andamento"
    },
    "prioridade_risco": {
      "type": "string",
      "enum": ["Baixa", "Média", "Alta", "Crítica"],
      "default": "Média"
    },
    "prorrogacoes_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["tipo_procedimento", "objeto"]
}