{
  "name": "Promocao",
  "type": "object",
  "title": "Promoção",
  "description": "Lote ou agrupamento estrutural de registros individuais de promoção.",
  "properties": {
    "tipo": { "type": "string", "default": "historica" },
    "natureza": { "type": "string", "default": "individual" },
    "posto_graduacao": { "type": "string", "default": "" },
    "quadro": { "type": "string", "default": "" },
    "data_promocao": { "type": "date", "default": "" },
    "data_publicacao": { "type": "date", "default": "" },
    "boletim_referencia": { "type": "string", "default": "" },
    "ato_referencia": { "type": "string", "default": "" },
    "status": { "type": "string", "default": "rascunho" },
    "origem": { "type": "string", "default": "manual" },
    "observacoes": { "type": "string", "default": "" },
    "chave_agrupamento": { "type": "string", "default": "" },
    "hash_agrupamento": { "type": "string", "default": "" },
    "total_militares_vinculados": { "type": "number", "default": 0 },
    "criado_por": { "type": "string", "default": "" },
    "criado_em": { "type": "datetime", "default": "" },
    "atualizado_por": { "type": "string", "default": "" },
    "atualizado_em": { "type": "datetime", "default": "" },
    "cancelado_por": { "type": "string", "default": "" },
    "cancelado_em": { "type": "datetime", "default": "" },
    "motivo_cancelamento": { "type": "string", "default": "" }
  }
}
