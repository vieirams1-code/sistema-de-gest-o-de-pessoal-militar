{
  "name": "Tag",
  "type": "object",
  "title": "Tag",
  "description": "Tag aplicável a militares e/ou férias com suporte a escopo.",
  "properties": {
    "grupo_id": {
      "type": "string",
      "default": ""
    },
    "nome": {
      "type": "string",
      "default": ""
    },
    "descricao": {
      "type": "string",
      "default": ""
    },
    "icone": {
      "type": "string",
      "default": ""
    },
    "emoji": {
      "type": "string",
      "default": ""
    },
    "cor": {
      "type": "string",
      "default": ""
    },
    "tipo_visual": {
      "type": "string",
      "enum": [
        "normal",
        "destaque",
        "alerta",
        "favorito",
        "critico"
      ],
      "default": "normal"
    },
    "aplicabilidade": {
      "type": "string",
      "enum": [
        "militar",
        "ferias",
        "ambos"
      ],
      "default": "ambos"
    },
    "ordem_exibicao": {
      "type": "number",
      "default": 0
    },
    "escopo_tipo": {
      "type": "string",
      "enum": [
        "global",
        "grupamento",
        "subgrupamento",
        "unidade",
        "setor",
        "subsetor"
      ],
      "default": "global"
    },
    "escopo_id": {
      "type": "string",
      "default": ""
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "created_by": {
      "type": "string",
      "default": ""
    },
    "updated_by": {
      "type": "string",
      "default": ""
    },
    "tipo_uso": {
      "type": "string",
      "enum": [
        "comum",
        "unica"
      ],
      "default": "comum",
      "description": "Define se a tag pode ser atribuída a múltiplos militares ou apenas a um militar ativo por vez."
    }
  },
  "required": [
    "nome"
  ],
  "_security": {
    "read": true,
    "create": "admin",
    "update": "admin",
    "delete": "admin"
  }
}
