{
  "name": "PublicacaoCompilada",
  "type": "object",
  "title": "Publicação Compilada",
  "description": "Lote compilado de publicações utilizado pelo frontend de Publicações e Conciliação de Boletim.",
  "properties": {
    "titulo": {
      "type": "string",
      "default": ""
    },
    "tipo_lote": {
      "type": "string",
      "default": "ferias"
    },
    "status": {
      "type": "string",
      "default": "Aguardando Publicação"
    },
    "nota_para_bg": {
      "type": "string",
      "default": ""
    },
    "numero_bg": {
      "type": "string",
      "default": ""
    },
    "data_bg": {
      "type": "string",
      "default": ""
    },
    "publicado_por": {
      "type": "string",
      "default": ""
    },
    "publicado_em": {
      "type": "string",
      "default": ""
    },
    "nota_conciliada_boletim": {
      "type": "string",
      "default": ""
    },
    "texto_publicacao": {
      "type": "string",
      "default": ""
    },
    "quantidade_itens": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "escopo_inicial": {
      "type": "string",
      "default": "ferias"
    },
    "origem": {
      "type": "string",
      "default": "livro"
    },
    "registros_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "criado_por": {
      "type": "string",
      "default": ""
    },
    "data_criacao_lote": {
      "type": "string",
      "default": ""
    },
    "observacoes": {
      "type": "string",
      "default": ""
    }
  }
}
