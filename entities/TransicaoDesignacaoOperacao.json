{
  "name": "TransicaoDesignacaoOperacao",
  "type": "object",
  "title": "Operação de Transição Manual de Designação",
  "description": "Registro de auditoria por período aquisitivo para futura transição manual de designação. Não executa alterações operacionais por si só.",
  "properties": {
    "lote_id": { "type": "string", "default": "" },
    "militar_id": { "type": "string", "default": "" },
    "contrato_designacao_id": { "type": "string", "default": "" },
    "periodo_aquisitivo_id": { "type": "string", "default": "" },
    "acao": { "type": "string", "enum": ["manter", "marcar_legado_ativa", "marcar_indenizado", "excluir_cadeia_operacional", "cancelar_periodo_futuro_indevido"], "default": "" },
    "acao_sugerida": { "type": "string", "default": "" },
    "override_sugestao": { "type": "boolean", "default": false },
    "motivo": { "type": "string", "default": "" },
    "observacao": { "type": "string", "default": "" },
    "documento_json": { "type": "string", "default": "" },
    "estado_anterior_json": { "type": "string", "default": "" },
    "estado_posterior_json": { "type": "string", "default": "" },
    "riscos_json": { "type": "string", "default": "" },
    "alertas_json": { "type": "string", "default": "" },
    "conflitos_json": { "type": "string", "default": "" },
    "bloqueantes_json": { "type": "string", "default": "" },
    "status_operacao": { "type": "string", "enum": ["registrada", "aplicada", "ignorada", "bloqueada", "falhou", "revertida"], "default": "registrada" },
    "aplicado_por": { "type": "string", "default": "" },
    "aplicado_em": { "type": "date", "default": "" },
    "rollback_em": { "type": "date", "default": "" },
    "rollback_por": { "type": "string", "default": "" },
    "rollback_motivo": { "type": "string", "default": "" }
  },
  "required": ["lote_id", "periodo_aquisitivo_id"]
}
